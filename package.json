{
  "name": "itsyconnect-macos",
  "version": "1.1.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/nickustinov/itsyconnect-macos"
  },
  "main": "electron/main.js",
  "scripts": {
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:prepare": "cp -r public .next/standalone/public && cp -r .next/static .next/standalone/.next/static && cp -r drizzle .next/standalone/drizzle && npx electron-rebuild -f -o better-sqlite3 --build-from-source && mkdir -p .next/standalone/node_modules/better-sqlite3/build/Release && cp node_modules/better-sqlite3/build/Release/better_sqlite3.node .next/standalone/node_modules/better-sqlite3/build/Release/better_sqlite3.node && npm rebuild better-sqlite3",
    "electron:dev": "npm run electron:compile && electron .",
    "electron:make:dmg": "npm run electron:compile && next build && npm run electron:prepare && electron-forge make --targets=@electron-forge/maker-dmg",
    "electron:make:mas": "MAS=1 npm run electron:compile && MAS=1 next build && npm run electron:prepare && MAS=1 electron-forge make"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.49",
    "@ai-sdk/google": "^3.0.33",
    "@ai-sdk/mistral": "^3.0.20",
    "@ai-sdk/openai": "^3.0.36",
    "@ai-sdk/xai": "^3.0.59",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@phosphor-icons/react": "^2.1.10",
    "ai": "^6.0.104",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "update-electron-app": "^3.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "drizzle-kit": "^0.31.9",
    "electron": "^40.6.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
